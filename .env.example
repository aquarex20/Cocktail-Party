## Copy to `.env` and fill in values. Do NOT commit `.env`.

## Required for WhisperX diarization (pyannote models on Hugging Face)
HUGGING_FACE_TOKEN=hf_your_token_here

## Voice chat ↔ diarization server wiring
DIARIZATION_SERVER_URL=http://127.0.0.1:8001

## CPU/GPU tuning
# DIARIZATION_DEVICE=auto|cpu|cuda
DIARIZATION_DEVICE=auto

# WhisperX STT tuning (used by `whisper_stt.py`)
# WHISPERX_DEVICE=auto|cpu|cuda|mps
WHISPERX_DEVICE=auto
# WHISPERX_COMPUTE_TYPE=int8|float16|float32
WHISPERX_COMPUTE_TYPE=
# WHISPERX_MODEL=tiny|base|small|medium|large-v2|...
WHISPERX_MODEL=small
# Minimum utterance duration in seconds (shorter audio is ignored)
WHISPER_MIN_AUDIO_S=0.12

## Diarization server refinement loop tuning
# DIARIZATION_REFINE_INTERVAL_S=10
# DIARIZATION_REFINE_MIN_S=30
# DIARIZATION_REFINE_MAX_S=120
# DIARIZATION_STORE_MAX_S=300

